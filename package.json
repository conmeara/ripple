{
  "name": "ripple-video",
  "version": "0.13.1",
  "description": "Open-source video-making toolkit for coding agents: local perception, creative workflow, persistent taste, verifiable edits, and NLE handoff.",
  "type": "module",
  "bin": {
    "ripple": "bin/ripple"
  },
  "files": [
    "bin/",
    "cli/",
    "!cli/*.test.mjs",
    "skills/ripple/",
    "agents/",
    "hooks/",
    "schemas/"
  ],
  "scripts": {
    "test": "node --test 'cli/*.test.mjs'"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "video",
    "editing",
    "video-editing",
    "ffmpeg",
    "whisper",
    "transcription",
    "captions",
    "agent",
    "claude-code",
    "codex",
    "cli"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conmeara/ripple.git"
  },
  "homepage": "https://github.com/conmeara/ripple#readme",
  "bugs": "https://github.com/conmeara/ripple/issues"
}
