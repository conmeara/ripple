# =============================================================================
# Open Source Build Configuration
# =============================================================================
# All variables below are OPTIONAL - the app works without them.
# Set them only if you need code signing, analytics, or local development
# overrides.
# =============================================================================

# Apple Developer credentials (required for macOS code signing & notarization)
# Skip these if you just want to run locally without signing. Official release
# builds read these values from GitHub Actions secrets.
APPLE_ID=your-email@example.com
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_IDENTITY=Developer ID Application: Your Name (TEAM_ID)
APPLE_API_KEY_ID=XXXXXXXXXX
APPLE_API_ISSUER=00000000-0000-0000-0000-000000000000
# APPLE_API_KEY=/absolute/path/to/AuthKey_XXXXXXXXXX.p8
# APPLE_API_KEY_P8="-----BEGIN PRIVATE KEY-----..."

# macOS certificate bundle for electron-builder release jobs
# CSC_LINK is the base64-encoded .p12 contents; CSC_KEY_PASSWORD unlocks it.
# Keep these in ignored local env files or GitHub Actions secrets only.
# CSC_LINK=base64-p12-contents
# CSC_KEY_PASSWORD=change-me

# Sentry error tracking is reserved and disabled.
# Crash telemetry is separate from analytics and must stay unset in official
# builds until Ripple has a separate crash-reporting consent preference and
# sanitizer.
# MAIN_VITE_SENTRY_DSN=https://xxxxx@xxx.ingest.sentry.io/xxxxx

# Ripple analytics (optional; main-process only; requires explicit user consent)
# MAIN_VITE_RIPPLE_ANALYTICS_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MAIN_VITE_RIPPLE_ANALYTICS_HOST=https://us.i.posthog.com
# MAIN_VITE_RIPPLE_ANALYTICS_FORCE=false
# Renderer analytics keys are intentionally omitted. Phase 16 routes analytics
# through a main-process consent boundary rather than a renderer PostHog client.

# Feedback issue URL (optional)
# VITE_FEEDBACK_ISSUE_URL=https://github.com/conmeara/ripple/issues/new

# Hosted Ripple API URL (optional - disabled if not set)
# MAIN_VITE_RIPPLE_API_URL=http://localhost:3000

# Ripple update feed URL (fallback only)
# Official packaged updates use electron-builder GitHub Releases metadata for
# conmeara/ripple. Set this only for explicit maintainer fallback-provider tests.
# MAIN_VITE_RIPPLE_UPDATE_URL=https://updates.example.com/ripple

# Voice Input (optional - uses OpenAI Whisper API)
# Set this to enable voice-to-text for users without a paid subscription
# Get your API key at https://platform.openai.com/api-keys
# MAIN_VITE_OPENAI_API_KEY=sk-...
