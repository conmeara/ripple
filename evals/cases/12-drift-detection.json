{
  "id": "12-drift-detection",
  "title": "Long-source whisper drift is detected and blocks the bad cut (no agent)",
  "agent": "none",
  "timeoutMinutes": 25,
  "fixtures": [
    { "from": "$CACHE/long_qanda.mp4", "to": "media/long_qanda.mp4" }
  ],
  "setup": [
    "$RIPPLE analyze media/long_qanda.mp4 > analyze.json",
    "$RIPPLE candidates media/long_qanda.mp4 --start 408.6 --end 441.0 --label q6_chore --no-sheet > candidates.json"
  ],
  "checks": [
    { "id": "index-self-check-runs", "type": "json_path", "file": "analyze.json", "path": "drift.stretchedEndings", "op": "gte", "value": 0 },
    { "id": "drift-suspected", "type": "json_path", "file": "analyze.json", "path": "drift.suspected", "op": "eq", "value": true },
    { "id": "drift-check-runs", "type": "json_path", "file": "candidates.json", "path": "driftCheck.deltaSeconds", "op": "exists" },
    { "id": "drifted-range-flagged", "type": "json_path", "file": "candidates.json", "path": "driftCheck.verdict", "op": "eq", "value": "drifted" },
    { "id": "no-suggestion-on-fiction", "type": "json_path", "file": "candidates.json", "path": "suggestedOut", "op": "eq", "value": null }
  ]
}
