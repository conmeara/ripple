{
  "id": "12-drift-detection",
  "title": "Long-source drift is prevented at the source; endpoint disagreement still blocks the cut (no agent)",
  "agent": "none",
  "timeoutMinutes": 25,
  "fixtures": [
    { "from": "$CACHE/long_qanda.mp4", "to": "media/long_qanda.mp4" }
  ],
  "setup": [
    "$RIPPLE analyze media/long_qanda.mp4 > analyze.json",
    "$RIPPLE candidates media/long_qanda.mp4 --start 408.6 --end 441.0 --label q6_chore --no-sheet > candidates.json"
  ],
  "checks": [
    { "id": "index-self-check-runs", "type": "json_path", "file": "analyze.json", "path": "drift.stretchedEndings", "op": "gte", "value": 0 },
    { "id": "drift-prevented", "type": "json_path", "file": "analyze.json", "path": "drift.suspected", "op": "eq", "value": false },
    { "id": "no-severe-late-endings", "type": "json_path", "file": "analyze.json", "path": "drift.lateSevereEndings", "op": "eq", "value": 0 },
    { "id": "drift-check-runs", "type": "json_path", "file": "candidates.json", "path": "driftCheck.deltaSeconds", "op": "exists" },
    { "id": "disagreement-still-flagged", "type": "json_path", "file": "candidates.json", "path": "driftCheck.verdict", "op": "eq", "value": "drifted" },
    { "id": "no-suggestion-on-disagreement", "type": "json_path", "file": "candidates.json", "path": "suggestedOut", "op": "eq", "value": null }
  ]
}
