{
  "id": "50-repair-codex",
  "title": "Codex repairs a cut-off ending without rebuilding the edit",
  "agent": "codex",
  "timeoutMinutes": 40,
  "prompt": "The interview answer in outputs/draft.mp4 got cut off at the end - repair it and re-render.",
  "fixtures": [
    {
      "from": "$CACHE/raw-interview.mp4",
      "to": "media/raw-interview.mp4"
    },
    {
      "from": "$FIXTURES/repair-edit.json",
      "to": "edit.json"
    },
    {
      "from": "$FIXTURES/VIDEO.md",
      "to": "VIDEO.md"
    }
  ],
  "setup": [
    "$RIPPLE analyze media/raw-interview.mp4",
    "$RIPPLE cut edit.json --profile draft --out outputs/draft.mp4 > setup-cut.json"
  ],
  "checks": [
    {
      "id": "used-ripple-cli",
      "type": "transcript_grep",
      "pattern": "(cli/index\\.mjs|\\bripple (analyze|candidates|transcribe|cut|qa|frame-sheet|timeline-sheet|probe|lint|history))"
    },
    {
      "id": "end-extended",
      "type": "json_path",
      "file": "edit.json",
      "path": "scenes.0.end",
      "op": "gte",
      "value": 26.6
    },
    {
      "id": "head-untouched-lo",
      "type": "json_path",
      "file": "edit.json",
      "path": "scenes.0.start",
      "op": "gte",
      "value": 5
    },
    {
      "id": "head-untouched-hi",
      "type": "json_path",
      "file": "edit.json",
      "path": "scenes.0.start",
      "op": "lte",
      "value": 7.2
    },
    {
      "id": "render-duration",
      "type": "duration_between",
      "glob": "outputs/*.mp4",
      "min": 19,
      "max": 23
    },
    {
      "id": "source-window-restored",
      "type": "audio_source_correlation",
      "glob": "outputs/*.mp4",
      "sources": ["media/raw-interview.mp4"],
      "minConfidence": 0.35,
      "minSourceStart": 5.5,
      "maxSourceStart": 7.5,
      "minSourceEnd": 26.6,
      "maxSourceEnd": 28.5
    },
    {
      "id": "hdr-preserved",
      "type": "color_transfer",
      "glob": "outputs/*.mp4",
      "expect": "arib-std-b67"
    }
  ]
}
