{
  "id": "30-tighten-codex",
  "title": "Codex tightens a raw take: drops slate + dead air, keeps the full answer, preserves HDR",
  "agent": "codex",
  "timeoutMinutes": 40,
  "prompt": "media/raw-interview.mp4 is a raw interview take: there's a slate and dead air at the head, and the speaker holds and clears their throat after finishing. Tighten it into a clean clip: start just before the real answer begins and end just after the last word with a natural tail. Render the result into outputs/.",
  "fixtures": [
    {
      "from": "$CACHE/raw-interview.mp4",
      "to": "media/raw-interview.mp4"
    },
    {
      "from": "$FIXTURES/VIDEO.md",
      "to": "VIDEO.md"
    }
  ],
  "checks": [
    {
      "id": "used-ripple-cli",
      "type": "transcript_grep",
      "pattern": "(cli/index\\.mjs|\\bripple (analyze|candidates|transcribe|cut|qa|frame-sheet|timeline-sheet|probe|lint|history))"
    },
    {
      "id": "manifest-written",
      "type": "file_exists",
      "glob": "edit.json"
    },
    {
      "id": "render",
      "type": "file_exists",
      "glob": "outputs/*.mp4"
    },
    {
      "id": "duration-tight",
      "type": "duration_between",
      "glob": "outputs/*.mp4",
      "min": 18.5,
      "max": 22.5
    },
    {
      "id": "source-window-preserved",
      "type": "audio_source_correlation",
      "glob": "outputs/*.mp4",
      "sources": ["media/raw-interview.mp4"],
      "minConfidence": 0.35,
      "minSourceStart": 5.5,
      "maxSourceStart": 7.5,
      "minSourceEnd": 26.6,
      "maxSourceEnd": 28.5
    },
    {
      "id": "hdr-preserved",
      "type": "color_transfer",
      "glob": "outputs/*.mp4",
      "expect": "arib-std-b67"
    }
  ]
}
