{
  "id": "20-routing-codex",
  "title": "Codex routes a plain footage question through the plugin",
  "agent": "codex",
  "timeoutMinutes": 10,
  "prompt": "What footage do I have in this project, and is any of it HDR?",
  "fixtures": [
    {
      "from": "$CACHE/answer-a.mp4",
      "to": "media/01_answer-a.mp4"
    },
    {
      "from": "$CACHE/answer-b.mp4",
      "to": "media/10_answer-b.mp4"
    },
    {
      "from": "$FIXTURES/VIDEO.md",
      "to": "VIDEO.md"
    }
  ],
  "checks": [
    {
      "id": "used-ripple-cli",
      "type": "transcript_grep",
      "pattern": "(index\\.mjs[^\\n]{0,60}probe|\\bripple probe)"
    },
    {
      "id": "names-clip-1",
      "type": "final_grep",
      "pattern": "answer-a"
    },
    {
      "id": "names-clip-2",
      "type": "final_grep",
      "pattern": "answer-b"
    },
    {
      "id": "answers-hdr",
      "type": "final_grep",
      "pattern": "HDR|HLG|bt2020|arib"
    }
  ]
}
