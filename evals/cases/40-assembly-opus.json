{
  "id": "40-assembly-opus",
  "title": "Claude Opus assembles two answers into one cut and QAs it",
  "agent": "claude",
  "model": "opus",
  "timeoutMinutes": 40,
  "prompt": "Assemble media/01_answer-a.mp4 followed by media/10_answer-b.mp4 into one video with a clean hard cut between them, then QA the result. Render to outputs/. Keep both spoken answers complete, but trim excess dead air so the join and ending each have a natural tail of no more than 1 second.",
  "fixtures": [
    {
      "from": "$CACHE/answer-a.mp4",
      "to": "media/01_answer-a.mp4"
    },
    {
      "from": "$CACHE/answer-b.mp4",
      "to": "media/10_answer-b.mp4"
    },
    {
      "from": "$FIXTURES/VIDEO.md",
      "to": "VIDEO.md"
    }
  ],
  "checks": [
    {
      "id": "used-ripple-cli",
      "type": "transcript_grep",
      "pattern": "(cli/index\\.mjs|\\bripple (analyze|candidates|transcribe|cut|qa|frame-sheet|timeline-sheet|probe|lint|history))"
    },
    {
      "id": "ran-qa",
      "type": "transcript_grep",
      "pattern": "(index\\.mjs[^\\n]{0,80}\\bqa\\b|\\bripple qa\\b)"
    },
    {
      "id": "manifest-written",
      "type": "file_exists",
      "glob": "edit.json"
    },
    {
      "id": "render",
      "type": "file_exists",
      "glob": "outputs/*.mp4"
    },
    {
      "id": "duration-both-scenes",
      "type": "duration_between",
      "glob": "outputs/*.mp4",
      "min": 40,
      "max": 50
    },
    {
      "id": "both-answers-present",
      "type": "audio_source_correlation",
      "glob": "outputs/*.mp4",
      "sources": ["media/01_answer-a.mp4", "media/10_answer-b.mp4"],
      "minConfidence": 0.35
    },
    {
      "id": "source-order",
      "type": "manifest_source_order",
      "manifest": "edit.json",
      "sources": ["media/01_answer-a.mp4", "media/10_answer-b.mp4"]
    },
    {
      "id": "audio-boundaries-clean",
      "type": "render_audio_boundaries",
      "glob": "outputs/*.mp4",
      "manifest": "edit.json",
      "minTail": 0.05,
      "maxTail": 1.0,
      "maxJoinSilence": 1.25,
      "minHardJoins": 1,
      "maxHardJoins": 1
    },
    {
      "id": "qa-verified",
      "type": "qa_snapshot",
      "glob": "outputs/*.mp4",
      "manifest": "edit.json",
      "status": "pass",
      "gates": ["render-freshness", "scene-tails", "tail-silence", "prompt-leak", "scene-endings"]
    },
    {
      "id": "hdr-preserved",
      "type": "color_transfer",
      "glob": "outputs/*.mp4",
      "expect": "arib-std-b67"
    }
  ]
}
