{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/conmeara/ripple/schemas/edit.schema.json",
  "title": "Ripple edit manifest",
  "description": "The single source of truth for an edit. Renders are derived from this file; user corrections patch it locally.",
  "type": "object",
  "required": [
    "version",
    "scenes"
  ],
  "properties": {
    "version": {
      "const": 1
    },
    "title": {
      "type": "string"
    },
    "color": {
      "type": "object",
      "properties": {
        "policy": {
          "enum": [
            "preserve",
            "sdr"
          ]
        },
        "source": {
          "type": "object",
          "description": "As detected by ripple probe (primaries/transfer/space)",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "width": {
          "type": "integer"
        },
        "height": {
          "type": "integer"
        },
        "fps": {
          "type": "string",
          "description": "e.g. 24000/1001"
        },
        "container": {
          "type": "string"
        },
        "fit": {
          "enum": [
            "pad",
            "crop"
          ],
          "default": "pad",
          "description": "pad letterboxes to the output frame; crop reframes (scale to cover, center-crop)."
        },
        "crop": {
          "type": "object",
          "required": [
            "x",
            "y",
            "w",
            "h"
          ],
          "properties": {
            "x": {
              "type": "integer",
              "minimum": 0
            },
            "y": {
              "type": "integer",
              "minimum": 0
            },
            "w": {
              "type": "integer",
              "minimum": 0
            },
            "h": {
              "type": "integer",
              "minimum": 0
            }
          },
          "description": "Source-pixel reframe rect applied before scaling (state it once after reading a full frame)."
        }
      }
    },
    "grade": {
      "type": "object",
      "description": "The chosen grade preset, recorded in the manifest per the deliver playbook (rendered by ripple cut)",
      "properties": {
        "name": {
          "type": "string"
        },
        "filter": {
          "type": [
            "string",
            "null"
          ],
          "description": "ffmpeg filter chain; null = neutral"
        }
      }
    },
    "music": {
      "type": "object",
      "description": "Optional music bed, mixed under dialogue in the full assembly only \u2014 per-scene clips stay clean (applied by ripple cut)",
      "required": [
        "source"
      ],
      "properties": {
        "source": {
          "type": "string",
          "description": "path to the bed audio file"
        },
        "gainDb": {
          "type": "number",
          "default": -18,
          "description": "bed level relative to dialogue, in dB (applied before ducking)"
        },
        "duck": {
          "type": "object",
          "description": "sidechain ducking driven by dialogue",
          "properties": {
            "threshold": {
              "type": "number",
              "default": 0.03,
              "description": "linear dialogue level that triggers ducking"
            },
            "ratio": {
              "type": "number",
              "default": 8
            }
          }
        },
        "fadeIn": {
          "type": "number",
          "default": 1.0,
          "description": "seconds"
        },
        "fadeOut": {
          "type": "number",
          "default": 2.0,
          "description": "seconds, ending at the assembly tail"
        },
        "loudnessTarget": {
          "type": "number",
          "description": "integrated LUFS for the final mix (e.g. -14 social, -23 broadcast); applied via loudnorm and verified by ripple qa"
        }
      }
    },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "slug",
          "source",
          "start",
          "end",
          "status"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "title": {
            "type": "string",
            "description": "e.g. the question card text"
          },
          "source": {
            "type": "string",
            "description": "path to source media"
          },
          "start": {
            "type": "number",
            "description": "seconds in source"
          },
          "end": {
            "type": "number"
          },
          "take": {
            "type": "string",
            "description": "which take was chosen, when sources have several"
          },
          "candidates": {
            "type": "array",
            "description": "other takes/ranges considered",
            "items": {
              "type": "object",
              "properties": {
                "start": {
                  "type": "number"
                },
                "end": {
                  "type": "number"
                },
                "note": {
                  "type": "string"
                }
              }
            }
          },
          "reasoning": {
            "type": "string",
            "description": "why this take and these bounds \u2014 always filled in"
          },
          "waivers": {
            "type": "array",
            "description": "Scene-tier rule waivers, read by ripple lint. Each names a registry rule id (reference/rules.md) and states why the finding is intentional \u2014 waivers surface as waived-with-reason, never silently dropped; one without a reason is ignored and reported.",
            "items": {
              "type": "object",
              "required": [
                "rule",
                "reason"
              ],
              "properties": {
                "rule": {
                  "type": "string",
                  "description": "registry rule id, e.g. DEAD_AIR_TAIL"
                },
                "reason": {
                  "type": "string"
                }
              }
            }
          },
          "status": {
            "enum": [
              "proposed",
              "locked",
              "repaired"
            ]
          },
          "expectEnding": {
            "type": "string",
            "description": "phrase the scene must end with; used by qa"
          },
          "card": {
            "type": "string",
            "description": "title card text preceding this scene, if any"
          },
          "cardFile": {
            "type": "string",
            "description": "pre-rendered card image (e.g. from HyperFrames/Remotion) instead of generated text card"
          },
          "cardDuration": {
            "type": "number",
            "default": 2.5
          },
          "jcut": {
            "type": "number",
            "description": "seconds of scene audio to start under the preceding card"
          },
          "gainDb": {
            "type": "number",
            "description": "Per-scene dialogue gain in dB \u2014 applied by cut to the clip, segments, and J/L-cut card audio. The fader for qa's dialogue-loudness spread."
          },
          "lcut": {
            "type": "number",
            "exclusiveMinimum": 0,
            "description": "Seconds of this scene's trailing audio playing under the FOLLOWING scene's card (picture leaves early; mirror of jcut). Requires the next scene to have a card; lcut + next jcut must fit inside its cardDuration."
          },
          "transition": {
            "type": "object",
            "required": [
              "type",
              "duration"
            ],
            "properties": {
              "type": {
                "enum": [
                  "dissolve",
                  "fadeblack"
                ]
              },
              "duration": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            },
            "description": "Transition ENTERING this scene from the previous segment (xfade/acrossfade). The overlap shortens the assembly by `duration`; must be shorter than both adjacent segments."
          }
        }
      }
    },
    "qa": {
      "type": "object",
      "properties": {
        "leakPatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "regexes that must NOT appear in the final transcript (prompts, direction, take slates)"
        },
        "maxTailSilence": {
          "type": "number",
          "default": 1.0
        },
        "maxLeadingSilence": {
          "type": "number",
          "default": 0.5
        },
        "maxLoudnessSpread": {
          "type": "number",
          "default": 3,
          "description": "Max LU spread of per-scene clip integrated loudness (dialogue-loudness gate); fix outliers with scene.gainDb."
        }
      }
    }
  }
}
