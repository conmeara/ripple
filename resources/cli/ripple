#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  SOURCE_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$SOURCE_DIR/$SOURCE"
done

SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
RESOURCES_DIR="$(cd -P "$SCRIPT_DIR/.." >/dev/null 2>&1 && pwd)"
CLI_SCRIPT="$RESOURCES_DIR/app.asar/out/main/ripple-cli.js"
APP_ASAR="$RESOURCES_DIR/app.asar"
APP_EXECUTABLE=""

for candidate in \
  "$SCRIPT_DIR/../../MacOS/Ripple" \
  "$SCRIPT_DIR/../../ripple" \
  "$SCRIPT_DIR/../../Ripple"
do
  if [[ -x "$candidate" ]]; then
    APP_EXECUTABLE="$candidate"
    break
  fi
done

if [[ -n "$APP_EXECUTABLE" && -f "$APP_ASAR" ]]; then
  export ELECTRON_RUN_AS_NODE=1
  exec "$APP_EXECUTABLE" "$CLI_SCRIPT" "$@"
fi

REPO_ROOT="$(cd "$SCRIPT_DIR/../.." 2>/dev/null && pwd)"
if [[ -f "$REPO_ROOT/scripts/ripple-cli.ts" ]] && command -v bun >/dev/null 2>&1; then
  exec bun "$REPO_ROOT/scripts/ripple-cli.ts" "$@"
fi

echo "Ripple CLI requires the packaged app runtime or Bun in development." >&2
exit 1
