#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  SOURCE_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$SOURCE_DIR/$SOURCE"
done

SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
RESOURCES_DIR="$(cd -P "$SCRIPT_DIR/.." >/dev/null 2>&1 && pwd)"
PACKAGED_CLI="$RESOURCES_DIR/app.asar.unpacked/node_modules/hyperframes/dist/cli.js"
APP_ASAR_NODE_MODULES="$RESOURCES_DIR/app.asar/node_modules"
APP_EXECUTABLE=""

for candidate in \
  "$SCRIPT_DIR/../../MacOS/Ripple" \
  "$SCRIPT_DIR/../../ripple" \
  "$SCRIPT_DIR/../../Ripple"
do
  if [[ -x "$candidate" ]]; then
    APP_EXECUTABLE="$candidate"
    break
  fi
done

if [[ -n "$APP_EXECUTABLE" && -f "$PACKAGED_CLI" ]]; then
  export NODE_PATH="$RESOURCES_DIR/app.asar.unpacked/node_modules:$APP_ASAR_NODE_MODULES${NODE_PATH:+:$NODE_PATH}"
  export ELECTRON_RUN_AS_NODE=1
  exec "$APP_EXECUTABLE" "$PACKAGED_CLI" "$@"
fi

REPO_ROOT="$(cd "$SCRIPT_DIR/../.." 2>/dev/null && pwd)"
if [[ -f "$REPO_ROOT/node_modules/hyperframes/dist/cli.js" ]]; then
  exec node "$REPO_ROOT/node_modules/hyperframes/dist/cli.js" "$@"
fi

if command -v bunx >/dev/null 2>&1; then
  exec bunx hyperframes "$@"
fi

echo "HyperFrames CLI is not available." >&2
exit 1
